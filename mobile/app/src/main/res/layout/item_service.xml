<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E24"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="1"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvServiceDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:text="2026-05-30"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.4"
            android:text="Zakończony"
            android:textColor="#9B7EDE"
            android:textAlignment="textEnd"
            android:textStyle="italic"/>
    </LinearLayout>

    <TextView android:id="@+id/tvServiceCar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="4dp"
        android:text="Toyota Yaris (WAW123)"/>

    <TextView android:id="@+id/tvServiceDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A0A0A0"
        android:lineSpacingExtra="4dp"
        android:text="Rodzaj: Wymiana oleju\nWarsztat: Auto-Naprawa\nKoszt: 350.00 PLN"/>

</LinearLayout>