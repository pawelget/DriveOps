<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E24"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/tvReportNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="R/2026/00001"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvReportCar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#9B7EDE"
        android:text="Toyota Yaris (WAW123)"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvReportDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A0A0A0"
        android:text="Wygenerowano: 2026-05-30\nKoszt naprawy: 350.00 PLN"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <Button
            android:id="@+id/btnDownloadPdf"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#4C9AFF"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:text="Pobierz"/>

        <Button
            android:id="@+id/btnSendEmail"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="#FFA500"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:text="Mail"/>

        <Button
            android:id="@+id/btnDeleteReport"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FF4C4C"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:text="Usuń"/>
    </LinearLayout>

</LinearLayout>